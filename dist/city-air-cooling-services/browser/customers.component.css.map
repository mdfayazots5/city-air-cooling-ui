
    .customers-page {
      padding: 2rem;
    }
    
    h1 {
      margin-bottom: 1.5rem;
    }
    
    .actions {
      margin-bottom: 1.5rem;
    }
    
    .actions input {
      padding: 0.5rem 1rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      width: 300px;
    }
    
    table {
      width: 100%;
      background: white;
      border-radius: 8px;
      overflow: hidden;
    }
    
    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid #eee;
    }
    
    th {
      background: #f8f9fa;
      font-weight: 600;
    }
    
    .btn-view, .btn-edit {
      padding: 0.25rem 0.75rem;
      margin-right: 0.5rem;
      border: none;
      border-radius: 4px;
      cursor: pointer;
    }
    
    .btn-view {
      background: #1a73e8;
      color: white;
    }
    
    .btn-edit {
      background: #28a745;
      color: white;
    }
  